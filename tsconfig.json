{
  "compilerOptions": {
    // 启用严格模式（包含多个严格类型检查）
    "strict": true,
    
    // 强制文件名大小写一致性（避免跨平台问题）
    "forceConsistentCasingInFileNames": true,
    
    // 其他推荐配置（根据你的项目需要）
    "target": "esnext", // 或 "es2020"
    "module": "esnext", // 或 "commonjs"
    "lib": ["esnext", "dom"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    
    // Vue 3 推荐配置
    "jsx": "preserve", // 如果使用 JSX
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    
    // 路径别名配置
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": ["node_modules", "dist"]
}